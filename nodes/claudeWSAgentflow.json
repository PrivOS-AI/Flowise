                    "options": [
                        "system",
                        "user"
                    ]
                },
                "content": {
                    "type": "string",
                    "variable": true
                }
            }
        },
        "claudewsUpdateFlowState": {
            "type": "array",
            "variable": true,
            "parameters": {
                "key": {
                    "type": "string",
                    "variable": false
                },
                "value": {
                    "type": "string",
                    "variable": true
                }
            }
        }
    },
    "example": {
        "claudewsRoomName": "Project X",
        "claudewsMessages": [
            {
                "role": "system",
                "content": "You are a helper."
            }
        ],
        "claudewsTaskName": "Analyze Data"
    }
