{
    "id": "3",
    "parameters": {
        "claudewsServer": {
            "type": "asyncOptions",
            "variable": false,
            "loadMethod": "listServers"
        },
        "claudewsRoomName": {
            "type": "string",
            "variable": true
        },
        "claudewsRoomId": {
            "type": "string",
            "variable": true
        },
        "claudewsRoomSessionKey": {
            "type": "string",
            "variable": true
        },
        "privosEndpointUrl": {
            "type": "string",
            "variable": true
        },
        "claudewsTaskName": {
            "type": "string",
            "variable": true
        },
        "claudewsTaskId": {
            "type": "string",
            "variable": true
        },
        "claudewsForceCreate": {
            "type": "boolean",
            "variable": false,
            "default": true
        },
        "claudewsMessages": {
            "type": "array",
            "variable": true,
            "parameters": {
                "role": {
                    "type": "options",
