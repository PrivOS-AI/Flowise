                    "type": "asyncOptions",
                    "variable": false,
                    "loadMethod": "listRuntimeStateKeys",
                    "freeSolo": true
                },
                "value": {
                    "type": "string",
                    "variable": true
                }
            }
        }
    },
    "example": {
        "loopBackToNode": "llmAgentflow_0",
        "maxLoopCount": 3,
        "fallbackMessage": "Loop limit reached.",
        "loopUpdateState": [
