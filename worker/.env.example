# =============================================================================
# PRIVOS CHAT WORKER - ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and update with your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB Configuration
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=privos_file_management

# -----------------------------------------------------------------------------
# Redis Configuration (for Celery)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password  # Uncomment if using password

# -----------------------------------------------------------------------------
# Worker Configuration
# -----------------------------------------------------------------------------
WORKER_CONCURRENCY=10

# -----------------------------------------------------------------------------
# Weaviate Configuration
# -----------------------------------------------------------------------------
WEAVIATE_URL=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_SECURE=false
WEAVIATE_API_KEY=  # Leave empty if no authentication

# -----------------------------------------------------------------------------
# LLM Configuration (if needed for translation)
# -----------------------------------------------------------------------------
LLM_HUB_API_KEY=

